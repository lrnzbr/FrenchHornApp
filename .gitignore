# Xcode
.DS_Store
!*.xcodeproj
!*.xcworkspace
!*.xcconfig
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.xcuserstate

# Xcode Derived Data
DerivedData/
.idea/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
Packages/
.build/
.swiftpm/xcode/

# CocoaPods
Pods/
# Do not ignore *.xcworkspace — Xcode’s embedded project.xcworkspace must be
# trackable so xcshareddata/swiftpm/Package.resolved can be committed (required
# for Xcode Cloud when automatic SPM resolution is disabled). Ignore CocoaPods’
# xcuserdata under the workspace instead (below).
project.xcworkspace/xcuserdata
podfile.lock

# Carthage
Carthage/Build/
Carthage/Checkouts/

# Accio dependency manager
Dependencies/
.accio/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/
fastlane/*.lock

# SwiftLint & SwiftFormat
.swiftlint.yml
.swiftformat

# Temporary Files and Logs
*.tmp
*.swp
*.xcuserdatad
*.xcuserdata
*.moved-aside
*.xcodeproj/*project.xcworkspace/xcuserdata
*.lock

# Build Artifacts
*.app
*.apk
*.ipa
*.dSYM
*.dSYMs/
*.xarchive
*.xcresult

# Simulator devices
*/CoreSimulator/

# User-specific files
*.orig
*~.nib~*

# Prevent committing private keys
*.pem
*.cer
*.mobileprovision
*.p12

# Archives
*.xcarchive

# iOS DeviceSupport
DeviceSupport/

# Playground
timeline.xctimeline
playground.xcworkspace

# Generated documentation
docs.json
*.docc

# Environment & Build Config
.env
.secret.swift

# Build folder
build/